# Rust
target/
**/*.rs.bk
Cargo.lock.bak

# macOS
.DS_Store

# Editor
.vscode/
.idea/
*.swp

# Coding-agent local working dir (worktrees, scratch, prompts).
# Per-checkout state, never worth committing.
.claude/

# Build output
/dist/
*.xcframework.zip

# Test artifacts
test-disks/*.img
!test-disks/.gitkeep

# Local Windows-VM test pipeline outputs. The orchestrator
# (scripts/test-windows-local.sh) writes per-iteration diag dirs to
# $TMPDIR by default, but if anything ends up in-tree we don't want
# it committed.
tmp/
docs/archive
*.vhd
nfs.img
nfs-*.img

# Test-harness scenario disk images. Each scenario in test-matrix.json
# points at diskimages/nfs-<scenario>.img, allocated by `init-image`
# and wiped by scripts/run-matrix.sh's EXIT trap. The directory itself
# is created on demand; nothing in it is worth committing.
/diskimages/

# Matrix test diagnostics — pulled from the Windows VM by
# scripts/test-windows-matrix.sh into test-diagnostics/run-<ts>/.
# Contains binary MFT dumps, chkdsk transcripts, NTFS event log;
# all reproducible from a re-run, none worth committing.
test-diagnostics/
diag/

# SSH key file for the test VM, used when ssh-agent is broken
# (consumed via SSH_OPTS in scripts/test-windows-local.sh — see header).
# Lives at the repo root only; never commit.
/privatekey
/privatekey.*
.test-env
