# Rust
target/
**/*.rs.bk
Cargo.lock.bak

# macOS
.DS_Store

# Editor
.vscode/
.idea/
*.swp

# Build output
/dist/
*.xcframework.zip

# Test artifacts
test-disks/*.img
!test-disks/.gitkeep

# Local Windows-VM test pipeline outputs. The orchestrator
# (scripts/test-windows-local.sh) writes per-iteration diag dirs to
# $TMPDIR by default, but if anything ends up in-tree we don't want
# it committed.
diag*
*.vhdx
nfs.img

# SSH key file for the test VM, used when ssh-agent is broken
# (consumed via SSH_OPTS in scripts/test-windows-local.sh — see header).
# Lives at the repo root only; never commit.
/privatekey
/privatekey.*
